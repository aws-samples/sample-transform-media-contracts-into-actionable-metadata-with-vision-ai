# Vite build-time env vars — used by the React frontend
# These are baked into the JS bundle at build time

# Cognito User Pool
# authority format: https://cognito-idp.<region>.amazonaws.com/<user-pool-id>
VITE_COGNITO_AUTHORITY=https://cognito-idp.us-west-2.amazonaws.com/your-user-pool-id
VITE_COGNITO_CLIENT_ID=your-cognito-app-client-id
VITE_COGNITO_DOMAIN=https://your-domain.auth.us-west-2.amazoncognito.com

# Optional: shown in the UI if branding.json is not configured in S3
VITE_RESULTS_BUCKET=your-contract-kb-bucket

# ── Server-side env vars (read by Express at runtime) ──────────────────────

# AgentCore orchestrator runtime ARN (output of MediaContractsRuntimes CDK stack)
ORCHESTRATOR_RUNTIME_ARN=arn:aws:bedrock-agentcore:us-west-2:123456789012:runtime/media_contracts_orchestrator_dev

# DynamoDB jobs table name (output of MediaContractsDynamoDB CDK stack)
JOBS_TABLE_NAME=media-contracts-jobs-dev

# S3 buckets
CONFIG_BUCKET=media-contracts-config-dev
RESULTS_BUCKET=media-contracts-results-dev
SOURCE_BUCKET=media-contracts-source-dev

AWS_REGION=us-west-2

# CORS — restrict Express server to this origin (set to your ECS/CloudFront URL in prod)
ALLOWED_ORIGIN=http://localhost:7870
