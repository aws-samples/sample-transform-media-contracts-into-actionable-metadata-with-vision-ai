# AWS
AWS_REGION=us-west-2
AWS_PROFILE=your-aws-profile

# Paths (relative to ui/ directory — defaults work for standard repo layout)
PIPELINE_DIR=..
PIPELINE_VENV=../../../.venv

# S3 bucket names — must match the values in the root .env
SOURCE_BUCKET=your-source-contracts-bucket
SOURCE_PREFIX=xml-versions/
RESULTS_BUCKET=your-contract-kb-bucket
CONFIG_BUCKET=your-media-contracts-config-bucket
CONFIG_BUCKET_PREFIX=ui-config/
CHAT_MODEL=us.anthropic.claude-sonnet-4-6
# AGENT_MODE=true  # uncomment to lock agent auto-selection, overrides UI toggle
